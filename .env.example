# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/tx_guardian
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_USER_ID=123456789

# Tenderly (simulation)
TENDERLY_ACCOUNT_SLUG=your-account
TENDERLY_PROJECT_SLUG=your-project
TENDERLY_ACCESS_KEY=your-api-key

# LLM (AI analysis — Gemini 2.0 Flash)
GEMINI_API_KEY=your-gemini-api-key

# Price APIs
COINGECKO_API_KEY=

# Block Explorer (Etherscan V2 — single key for all EVM chains)
ETHERSCAN_API_KEY=your-etherscan-api-key

# Safe API (developer.safe.global — Builder plan = 50K req/month free)
SAFE_API_KEY=your-safe-jwt-token

# Safe Webhooks (requires Growth plan €199/mo)
SAFE_WEBHOOK_SECRET=
WEBHOOK_ENABLED=false

# App
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Sentry (error tracking)
SENTRY_DSN=

# Polling intervals
SAFE_POLLING_INTERVAL_MS=60000
SAFE_STANDBY_INTERVAL_MS=60000
SAFE_ACTIVE_INTERVAL_MS=30000
SMART_POLLING_INACTIVITY_MINUTES=30
EOA_POLLING_INTERVAL_MS=15000
PRICE_CACHE_TTL_SECONDS=60

# Registration (set to "false" to restrict to allowed_users table only)
# REGISTRATION_OPEN=false
