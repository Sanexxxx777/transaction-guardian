{
  "name": "transaction-guardian",
  "version": "1.0.0",
  "description": "Safe Wallet transaction monitoring and analysis bot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/generated/prisma && cp -r src/generated/prisma/. dist/generated/prisma/",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "safe-wallet",
    "telegram-bot",
    "defi",
    "monitoring"
  ],
  "author": "Aleksandr Shulgin (@Aleksandr_NFA)",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^10.38.0",
    "@types/node": "^25.0.10",
    "axios": "^1.13.4",
    "bullmq": "^5.67.2",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "fastify": "^5.7.2",
    "grammy": "^1.39.3",
    "ioredis": "^5.9.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
